# VocaFlow 环境变量
# 复制本文件为 .env.local 并填入实际值

# DeepSeek API 密钥 (必需，用于 LLM 推理)
# 获取方式: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SQLite 数据库路径 (可选，默认 data/vocaflow.sqlite)
# VOCAFLOW_SQLITE_PATH=data/vocaflow.sqlite

# -- 语音网关与 TTS --

# 豆包 TTS API 密钥 (语音播报必需)
# 获取方式: 火山引擎控制台 → 语音合成 → 双向流式 TTS
VOLCENGINE_TTS_API_KEY=

# 默认音色 (必需，seed-tts-2.0 兼容的音色 ID)
VOLCENGINE_TTS_SPEAKER=

# TTS 资源 ID (可选，默认 seed-tts-2.0)
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0

# 语音网关监听地址 (可选，默认 127.0.0.1:3101)
VOICE_GATEWAY_HOST=127.0.0.1
VOICE_GATEWAY_PORT=3101

# 语音网关允许的来源 Origin (可选，默认 localhost:3000)
VOICE_GATEWAY_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 浏览器连接语音网关的 WebSocket 地址 (可选，默认 ws://localhost:3101)
NEXT_PUBLIC_VOICE_GATEWAY_URL=ws://localhost:3101
